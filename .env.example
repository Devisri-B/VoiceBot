# SignalWire Credentials (from https://signalwire.com)
SIGNALWIRE_PROJECT_ID=your_project_id_here
SIGNALWIRE_API_TOKEN=your_api_token_here
SIGNALWIRE_SPACE_URL=yourspace.signalwire.com
SIGNALWIRE_FROM_NUMBER=+1XXXXXXXXXX

# Target phone number to test
TARGET_PHONE_NUMBER=+18054398008

# Ngrok URL (set after starting ngrok)
NGROK_URL=https://xxxx.ngrok-free.app

# Ollama settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Whisper settings
WHISPER_MODEL_SIZE=base

# Call settings
SILENCE_THRESHOLD_MS=700
TRIAL_MESSAGE_DURATION_S=0
MAX_CALL_DURATION_S=180
